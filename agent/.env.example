# Agent environment — copy to .env and fill in values
# NEVER commit .env to git

# ── Required ──────────────────────────────────────────────────────────────────
PRIVATE_KEY=                          # Agent wallet private key (fresh wallet, funded with OKB)
SIGNAL_ATTESTOR=0x1206EeBBAEd24039bDDd0C25BFf53a44c57ff59E
AGENT_WALLET=0xC8D92Bfd397A7ccaaf6B44466F2951070A3947C3

# ── Network ───────────────────────────────────────────────────────────────────
RPC_URL=https://rpc.xlayer.tech
CHAIN_ID=196

# ── Signal gate ───────────────────────────────────────────────────────────────
MIN_SCORE_DELTA=3                     # Write suppressed if |Δscore| <= this
HEARTBEAT_SECS=14400                  # 4h: forced write even if score unchanged
MAX_TX_PER_DAY=6000                   # Hard daily TX cap
LOOP_INTERVAL_MS=60000                # 60s compute cycle

# ── Polybot sidecar ───────────────────────────────────────────────────────────
POLYBOT_URL=http://localhost:8001     # Local dev. Set to Railway URL in prod.
