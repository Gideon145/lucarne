{
  "name": "lucarne-mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server exposing Lucarne's on-chain football intelligence to LLMs (Claude Desktop, Cursor, Continue, etc.) and HTTP subscribers.",
  "license": "MIT",
  "bin": {
    "lucarne-mcp": "dist/stdio.js"
  },
  "main": "dist/stdio.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/http.js",
    "start:stdio": "node dist/stdio.js",
    "dev": "tsx watch src/http.ts",
    "dev:stdio": "tsx watch src/stdio.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "express": "^4.21.2",
    "node-fetch": "^3.3.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "lucarne",
    "football",
    "world-cup",
    "x-layer",
    "okx"
  ]
}
